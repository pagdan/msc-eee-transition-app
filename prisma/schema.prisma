generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// User model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  studentId     String?   @unique
  image         String?
  programme     String?   @default("MSc EEE")
  yearOfStudy   Int?      @default(1)
  emailVerified DateTime?
  role  String  @default("student") // "student" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  calendarEvents CalendarEvent[]
  wellbeingLogs WellbeingLog[]

  @@map("users")
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Calendar Events
model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  location    String?
  startTime   DateTime
  endTime     DateTime
  isAllDay    Boolean  @default(false)
  category    String?  // "academic", "orientation", "social", "deadline"
  outlookId   String?  @unique // Microsoft Outlook event ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}

// Club
model Club {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  category    String   // "Academic", "Social", "Technical", "Professional"
  imageUrl    String?
  memberCount Int      @default(0)
  contactEmail String?
  website     String?
  isActive    Boolean  @default(true)
  instagram   String?
  facebook    String?
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("clubs")
}

// Dining Locations
model DiningLocation {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  location    String
  cuisine     String[]
  priceRange  String   // "$", "$$", "$$$"
  openingHours String?
  imageUrl    String?
  rating      Float?   @default(0)
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("dining_locations")
}

// Study Spots
model StudySpot {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  location    String
  capacity    String   // "small", "medium", "large"
  amenities   String[] // ["wifi", "power_outlets", "quiet", "group_study"]
  openingHours String?
  imageUrl    String?
  rating      Float?   @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("study_spots")
}

// Events (for dashboard upcoming events section)
model Event {
  id          String   @id @default(cuid())
  title       String
  subtitle    String   @db.Text
  date        DateTime
  imageUrl    String?
  content     String?  @db.Text // Full event description for detail page
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

// Contact form submissions
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("new") // new, read, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}
